{
  "buildCommand": "",
  "outputDirectory": "website",
  "installCommand": "",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/cn", "destination": "/cn/index.html" },
    { "source": "/jp", "destination": "/jp/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, immutable" }
      ]
    }
  ]
}
